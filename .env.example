# ============================================================
# Amamma Jaadi — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to Git
# ============================================================

# ── Admin Authentication ─────────────────────────────────────
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
ANALYTICS_PIN=your_analytics_pin
SESSION_SECRET=your_64_char_random_string

# ── Supabase Database ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Square Payments ──────────────────────────────────────────
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_URL=https://yourdomain.com/api/payments/webhook
NEXT_PUBLIC_SQUARE_APP_ID=your_square_application_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
# Loads the matching Web Payments SDK on the client (sandbox | production)
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# ── Resend Email (optional) ──────────────────────────────────
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=orders@yourdomain.com

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number
